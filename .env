# ============================================================
# Agent Platform — Auto-configured Environment
# PostgreSQL + Redis are auto-started locally (no Railway needed)
# ============================================================

# Database (Embedded PostgreSQL 18 - auto-started by instrumentation.ts)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/agent_platform
DATABASE_SSL=false
PG_PORT=5433
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB_NAME=agent_platform
PG_DATA_DIR=/home/z/my-project/data/db
PG_AUTO_START=true
PG_RESET_ON_START=false

# Redis (in-memory fallback for dev - no installation needed)
# Set REDIS_URL to enable real Redis (optional)
REDIS_URL=

# Security - auto-generated
ENCRYPTION_KEY=t2EKjUxFU37Sia9NsitmAW2/vbJU0wX2YjALlZI2JI0=
JWT_SECRET=8df30f799c82b4fb1cdfca69f1afc6856be952566f7d0f971da42798465e1bde
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# Observability
LOG_LEVEL=info
DB_LOG=false
NODE_ENV=development
SERVICE_NAME=agent-platform
PORT=3000

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# Embeddings (uses JSON storage when pgvector not available)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
